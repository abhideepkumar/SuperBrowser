# Copy this file to .env and fill in your values.
# DO NOT commit .env to git — it contains real API keys.

# ──── Provider Selection ──────────────────────────────────
# Which LLM provider to use: openai | nvidia | llamacpp
LLM_PROVIDER=openai

# Model name (provider-specific — see examples below per provider)
MODEL_NAME=gpt-4o

# ──── OpenAI / OpenRouter Configuration ───────────────────
# Used when LLM_PROVIDER=openai
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_BASE_URL=https://api.openai.com/v1

# For OpenRouter (free & paid models):
#   OPENAI_API_KEY=sk-or-v1-your-openrouter-key-here
#   OPENAI_BASE_URL=https://openrouter.ai/api/v1
#   MODEL_NAME=google/gemma-3-27b-it:free

# ──── NVIDIA NIM Configuration ────────────────────────────
# Used when LLM_PROVIDER=nvidia
# Get your key at: https://build.nvidia.com/
# NVIDIA_API_KEY=nvapi-your-nvidia-key-here
# NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
# MODEL_NAME=qwen/qwen3-235b-a22b-instruct

# ──── llama.cpp / Local Server Configuration ──────────────
# Used when LLM_PROVIDER=llamacpp
# Also works with Ollama, LM Studio, vLLM, or any OpenAI-compatible local server.
# LLAMACPP_URL=http://localhost:8080
# LLAMACPP_MODEL=local-model

# ──── General Settings ────────────────────────────────────
# Max number of loop iterations before the agent gives up
MAX_STEPS=20

# Enable vision (screenshot) input to the LLM.
# Set to "false" if your model is text-only.
# When "true", the agent automatically falls back to text-only if the model
# rejects the image — so it is safe to leave enabled.
ENABLE_VISION=true

# ──── Server Settings (used by npm run server) ────────────
# Port for the API/WebSocket server
SERVER_PORT=3000

# ──── Credentials (site-specific) ────────────────────────
# Env vars starting with CRED_ are auto-converted to placeholders:
#   CRED_EMAIL=user@example.com    → {{EMAIL}}  in the agent
#   CRED_PASSWORD=secret123        → {{PASSWORD}} in the agent
# CRED_EMAIL=user@example.com
# CRED_PASSWORD=secret123
