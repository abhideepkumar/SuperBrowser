# Copy this file to .env and fill in your values.

# ──── Provider Selection ──────────────────────────────────
# Which LLM provider to use: openai | nvidia | llamacpp
LLM_PROVIDER=nvidia

# Model name (provider-specific, e.g. gpt-4o, google/gemma-4-31b-it:free, etc.)
MODEL_NAME=qwen/qwen3-next-80b-a3b-instruct

# ──── OpenAI / OpenRouter Configuration ───────────────────
# Used when LLM_PROVIDER=openai
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
# For OpenRouter:
#   OPENAI_API_KEY=sk-or-v1-your-key-here
#   OPENAI_BASE_URL=https://openrouter.ai/api/v1
#   MODEL_NAME=anthropic/claude-3.5-sonnet

# ──── NVIDIA NIM Configuration ────────────────────────────
# Used when LLM_PROVIDER=nvidia
NVIDIA_API_KEY=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
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# ──── llama.cpp / Local Server Configuration ──────────────
# Used when LLM_PROVIDER=llamacpp
# Also works with Ollama, LM Studio, vLLM, or any local OpenAI-compatible server.
# LLAMACPP_URL=http://localhost:8080
# LLAMACPP_MODEL=local-model

# ──── General Settings ────────────────────────────────────
# Max number of loop iterations before the agent gives up
MAX_STEPS=20

# Enable vision (screenshot) input to the LLM.
# Set to "false" if your model doesn't support image inputs (text-only models).
# When "true", the agent will automatically fall back to text-only if the model
# rejects the image, so you can safely leave this enabled.
ENABLE_VISION=true

# ──── Credentials (site-specific) ────────────────────────
# Any environment variables starting with CRED_ will automatically be converted
# to placeholders (e.g., CRED_EMAIL -> {{EMAIL}}, CRED_PASSWORD -> {{PASSWORD}})
# and securely substituted before executing browser commands.
# CRED_EMAIL=user@example.com
# CRED_PASSWORD=secret123
