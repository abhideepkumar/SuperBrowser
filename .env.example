# Copy this file to .env and fill in your values.
# DO NOT commit .env to git — it contains real API keys.

# ──── Provider Selection ──────────────────────────────────
# Single provider:
LLM_PROVIDER=openai

# Provider-level fallback chain (comma-separated, tried in order):
# If all OpenAI keys fail → tries NVIDIA → tries local LlamaCpp
# LLM_PROVIDER=openai,nvidia,llamacpp

# Model name (provider-specific — see examples below per provider)
MODEL_NAME=gpt-4o

# ──── OpenAI / OpenRouter Configuration ───────────────────
# Used when LLM_PROVIDER=openai (or openai appears in the chain)
#
# Primary key (required):
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
#
# Backup keys — tried automatically if the primary key is rate limited (429)
# or returns an auth error (401). Add as many as you need.
# OPENAI_API_KEY_2=sk-your-backup-key
# OPENAI_BASE_URL_2=https://api.openai.com/v1  # can point to a different endpoint
# OPENAI_API_KEY_3=sk-your-third-key
# OPENAI_BASE_URL_3=https://openrouter.ai/api/v1  # e.g. key3 uses OpenRouter
#
# For OpenRouter only:
#   OPENAI_API_KEY=sk-or-v1-your-openrouter-key-here
#   OPENAI_BASE_URL=https://openrouter.ai/api/v1
#   MODEL_NAME=google/gemma-3-27b-it:free

# ──── NVIDIA NIM Configuration ────────────────────────────
# Used when LLM_PROVIDER=nvidia or nvidia appears in the chain
# Get your key at: https://build.nvidia.com/
# NVIDIA_API_KEY=nvapi-your-primary-key
# NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
# NVIDIA_API_KEY_2=nvapi-your-backup-key  # rotated on rate limit
# MODEL_NAME=qwen/qwen3-235b-a22b-instruct

# ──── llama.cpp / Local Server Configuration ──────────────
# Used when LLM_PROVIDER=llamacpp
# Also works with Ollama, LM Studio, vLLM, or any OpenAI-compatible local server.
# LLAMACPP_URL=http://localhost:8080
# LLAMACPP_MODEL=local-model

# ──── General Settings ────────────────────────────────────
# Max number of loop iterations before the agent gives up
MAX_STEPS=20

# Enable vision (screenshot) input to the LLM.
# Set to "false" if your model is text-only.
# When "true", the agent automatically falls back to text-only if the model
# rejects the image — so it is safe to leave enabled.
ENABLE_VISION=true

# ──── Server Settings (used by npm run server) ────────────
# Port for the API/WebSocket server
SERVER_PORT=3000

# ──── Credentials (site-specific) ────────────────────────
# Env vars starting with CRED_ are auto-converted to placeholders:
#   CRED_EMAIL=user@example.com    → {{EMAIL}}  in the agent
#   CRED_PASSWORD=secret123        → {{PASSWORD}} in the agent
# CRED_EMAIL=user@example.com
# CRED_PASSWORD=secret123
